<div class="critic-card">
    <div class="card-img">
        <img src={{image}} alt={{fullName}}>
    </div>
    <div class="critic-info">
        <h1>{{fullName}}</h1>
        <div>
            <h3>Age:</h3><span>{{age}}</span>
        </div>
        <div>
            <h3>Place of born:</h3><span>{{placeOfBorn}}</span>
        </div>
        {{!-- <h3>Review:</h3><span>{{content}}</span> --}}
    </div>
</div>