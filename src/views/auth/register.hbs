{{setTitle "Register"}}

<section id="register-page">
    <div class="registerSection">
        <div class="info-register">
            <h2>"All happy families are alike; each unhappy family is unhappy in its own way."</h2>
        </div>
        <form method="post" class="registerForm">
            <h2>Register</h2>
            <ul class="noBullet">
                <li>
                    <label for="email">Email:</label>
                    <input type="text" class="inputFields" id="email" name="email" value="{{userData.email}}" />
                    {{>error errors.email}}
                </li>
                <li>
                    <label for="password">Password:</label>
                    <input type="password" class="inputFields" id="password" name="password" />
                    {{>error errors.password}}
                </li>
                <li>
                    <label for="repeat-password">Repeat-Password:</label>
                    <input type="password" class="inputFields" id="repeat-password" name="repeatPassword" />
                    {{>error errors.repeatPassword}}
                </li>
                <li id="center-btn">
                    <button id="join-btn">Register</button>
                </li>
            </ul>
        </form>
    </div>
    <div class="register-login-links">
        <span>Already have an account? Go to <a href="/auth/login">login</a></span>
    </div>
</section>