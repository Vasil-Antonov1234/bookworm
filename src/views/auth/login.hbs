<section id="login-page">

    <div class="loginSection">
        <div class="info">
            <h2>"Whether you think you can, or you think you can't, you're right."</h2>
        </div>
        <form action="#" method="" class="loginForm">
            <h2>Login</h2>
            <ul class="noBullet">
                <li>
                    <label for="email">Email:</label>
                    <input type="text" class="inputFields" id="email" name="" />
                </li>
                <li>
                    <label for="password">Password:</label>
                    <input type="password" class="inputFields" id="password" name="" />
                </li>

                <li id="center-btn">
                    <button id="login-btn">Login</button>
                </li>
            </ul>
        </form>
    </div>
    <div class="register-login-links">
        <span>Don't have an account yet? Go to <a href="/auth/register">register</a></span>
    </div>

</section>