<section id="edit-page">
    <div class="editSection">
        <div class="info-edit">
            <h2>"It was a bright cold day in April, and the clocks were striking thirteen."</h2>
        </div>

        <form method="post" class="editForm">
            <h2>Edit Post</h2>
            <ul class="noBullet">
                <li>
                    <label for="title">Title:</label>
                    <input type="text" class="inputFields" id="title" name="title" value="{{book.title}}" />
                </li>
                <li>
                    <label for="category">Category:</label>
                    <select id="category" class="inputFields" name="category">
                        <option value="">Select Category</option>
                        <option value="novel" selected>Novel</option>
                        <option value="poetry">Poetry</option>
                        <option value="biography">Biography</option>
                        <option value="non-fiction">Non-Fiction</option>
                        <option value="short-story">Short Story</option>
                    </select>
                </li>
                <li>
                    <label for="genre">Genre:</label>
                    <input type="text" class="inputFields" id="genre" name="genre" value="{{book.genre}}" />
                </li>
                <li>
                    <label for="author">Author:</label>
                    <input type="text" class="inputFields" id="author" name="author" value="{{book.author}}" />
                </li>
                <li>
                    <label for="date">Year:</label>
                    <input type="number" class="inputFields" id="year" name="year" value="{{book.year}}" />
                </li>
                <li>
                    <label for="image">Book Cover:</label>
                    <input type="text" class="inputFields" id="image" name="imageUrl"
                        value={{book.imageUrl}} />
                </li>
                <li>
                    <label for="image">Rating:</label>
                    <input type="text" class="inputFields" id="rating" name="rating" value="{{book.rating}}" />
                </li>
                <li>
                    <label for="description">Description:</label>
                    <textarea id="description" class="inputFields"
                        name="description">{{book.description}}</textarea>
                </li>
                <li id="center-btn">
                    <button id="edit-btn">Edit</button>
                </li>
            </ul>
        </form>

    </div>
</section>