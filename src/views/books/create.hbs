<section id="create-page">
    <div class="createSection">
        <div class="info">
            <h2>"It is a truth universally acknowledged, that a single man in possession of a good fortune must be in
                want of a wife." -Pride and Prejudice, 1813</h2>
        </div>

        <form method="post" class="createForm">
            <h2>Add Book</h2>
            <ul class="noBullet">
                <li>
                    <label for="title">Title:</label>
                    <input type="text" class="inputFields" id="title" name="title" />
                </li>
                <li>
                    <label for="category">Category:</label>
                    <select id="category" class="inputFields" name="category">
                        <option value="">Select Category</option>
                        <option value="novel">Novel</option>
                        <option value="poetry">Poetry</option>
                        <option value="biography">Biography</option>
                        <option value="non-fiction">Non-Fiction</option>
                        <option value="short-story">Short Story</option>
                    </select>
                </li>
                <li>
                    <label for="genre">Genre:</label>
                    <input type="text" class="inputFields" id="genre" name="genre" />
                </li>
                <li>
                    <label for="author">Author:</label>
                    <input type="text" class="inputFields" id="author" name="author" />
                </li>
                <li>
                    <label for="date">Year:</label>
                    <input type="number" class="inputFields" id="year" name="year" />
                </li>
                <li>
                    <label for="image">Book Cover:</label>
                    <input type="text" class="inputFields" id="image" name="iamgeUrl" />
                </li>
                <li>
                    <label for="image">Rating:</label>
                    <input type="text" class="inputFields" id="rating" name="rating" />
                </li>
                <li>
                    <label for="description">Description:</label>
                    <textarea id="description" class="inputFields" name="description"></textarea>
                </li>

                <li id="center-btn">
                    <button id="create-btn">Add Book</button>
                </li>
            </ul>
        </form>


    </div>
</section>