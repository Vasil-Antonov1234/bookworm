<section id="details-page">

    <div class="main_card">
        <div class="card_left">
            <div class="card_datails">

                <h1>{{title}}</h1>
                <div class="card-book">
                    <div class="first-info">
                        <p class="card-genre">Genre: {{genre}}</p>
                        <p class="card-director">Author: {{author}}</p>
                    </div>
                    <div class="second-info">
                        <p class="card-year">Year: {{year}}</p>
                        <p class="card-ranking">Rating: <span id="stars">{{rating}}&#x2605;</span></p>
                    </div>

                </div>

                <p class="disc">Description: {{description}}</p>
                <p class="card-category">Category: {{category}}</p>
            </div>
            <div class="details-btn">
                <button id="edit-button">Edit</button>
                <button id="delete-button">Delete</button>
            </div>
        </div>
        <div class="card_right">
            <img src={{imageUrl}} alt={{title}}>
        </div>
    </div>

    <div class="main-review-card">
        <div class="no-review">
            <p>There are no reviews added yet...</p>
        </div>
    </div>

</section>